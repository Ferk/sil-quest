#!/usr/bin/env bash
#
# Depending on the host OS, this script generates a debug build of the Sil-Q app
# with only the GCU frontend enabled for either Linux or macOS.
#
# Requires ASan and UBsan installed.
#

set -euo pipefail

###############################################################################
# Configuration
###############################################################################

# shellcheck disable=SC2155
readonly SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)
# shellcheck disable=SC2155
readonly PROJECT_DIR=$(cd "$SCRIPT_DIR/.." && pwd -P)
# Use a different build directory than `bin/dev-build-mac` (macOS Cocoa app)
# so that switching between the two macOS builds doesn't require cleaning the
# build directory first.
readonly BUILD_DIR_CONSOLE="$PROJECT_DIR/build-console"
readonly SIL_EXE="sil"

###############################################################################
# Validate the environment
###############################################################################

# shellcheck disable=SC2155
readonly OS="$(uname)"
if ! [[ $OS == "Linux" || $OS == "Darwin" ]]; then
    echo "ERROR: This script must be run on Linux or macOS"
    exit 1
fi

###############################################################################
# Run the build
###############################################################################

OS_NAME="$OS"
if [[ $OS_NAME == "Darwin" ]]; then
    OS_NAME="macOS"
fi
readonly OS_NAME

echo "========================================================================"
echo "Generating a debug build for $OS_NAME with GCU frontend"
echo "========================================================================"

cd "$PROJECT_DIR"
cmake -G Ninja -B "$BUILD_DIR_CONSOLE" -DCMAKE_BUILD_TYPE=Debug -DSUPPORT_COCOA_FRONTEND=OFF -DSUPPORT_X11_FRONTEND=OFF -DBUILD_ENABLE_WERROR=ON -DBUILD_ENABLE_SANITIZERS=ON
cmake --build "$BUILD_DIR_CONSOLE"
cp "$BUILD_DIR_CONSOLE/$SIL_EXE" "./$SIL_EXE"

echo "========================================================================"
echo "Run the game via '$SIL_EXE' in the top-level project folder"
