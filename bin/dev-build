#!/usr/bin/env bash
#
# Generates a debug build of the Sil-Q terminal frontend for Linux or macOS.
#
# Requires ASan and UBsan installed.
#

set -euo pipefail

###############################################################################
# Configuration
###############################################################################

# shellcheck disable=SC2155
readonly SCRIPT_DIR=$(cd -- "$(dirname -- "${BASH_SOURCE[0]}")" &>/dev/null && pwd)
# shellcheck disable=SC2155
readonly PROJECT_DIR=$(cd "$SCRIPT_DIR/.." && pwd -P)
readonly BUILD_DIR="$PROJECT_DIR/build"
readonly SIL_EXE="sil"

###############################################################################
# Validate the environment
###############################################################################

# shellcheck disable=SC2155
readonly OS="$(uname)"
if ! [[ $OS == "Linux" || $OS == "Darwin" ]]; then
    echo "ERROR: This script must be run on Linux or macOS"
    exit 1
fi

###############################################################################
# Run the build
###############################################################################

OS_NAME="$OS"
if [[ $OS_NAME == "Darwin" ]]; then
    OS_NAME="macOS"
fi
readonly OS_NAME

echo "========================================================================"
echo "Generating a debug build for the $OS_NAME terminal frontend"
echo "========================================================================"

cd "$PROJECT_DIR"
cmake -G Ninja -B "$BUILD_DIR" -DCMAKE_BUILD_TYPE=Debug -DBUILD_ENABLE_WERROR=ON -DBUILD_ENABLE_SANITIZERS=ON
cmake --build "$BUILD_DIR"
cp "$BUILD_DIR/$SIL_EXE" "./$SIL_EXE"

echo "========================================================================"
echo "Run the game via '$SIL_EXE' in the top-level project folder"
